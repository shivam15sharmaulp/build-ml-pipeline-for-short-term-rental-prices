name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: raw uncleaned data
        type: string

      output_artifact:
        description: cleaned data
        type: string

      output_type:
        description: type of the output artifact
        type: string

      output_description:
        description: cleanerd data with some basic cleaning applied
        type: string

      min_price:
        description: lower bound for the price column
        type: float
        default: 10.0

      max_price:
        description: upper bound for the price column
        type: float
        default: 350.0


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
